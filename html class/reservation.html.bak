<center><p>Reserve a Table:</p></center>
<center><form method="post" action="">
	<table>
	<tr>
		<td>Full Name:</td>
		<td><input type="text" name="" required></td>
	</tr>
	<tr>
		<td>Email:</td>
		<td><input type="email" name="" required></td>
	</tr>
	<tr>
		<td>Phone:</td>
		<td><input type="tel" name="" required></td>
	</tr>
	<tr>
		<td>Date to visit:</td>
		<td><input type="date" name="" required></td>
	</tr>
	<tr>
		<td>Time:</td>
		<td><input type="time" name="" ></td>
	</tr>
	<tr>
		<td>Numbers of guests:</td>
		<td><select>
		<option> 1</option>
		<option> 2</option>
		<option> 3</option>
		<option> 4</option>
		<option> 5</option>

		</select>
		</td>
	</tr>
	<tr>
		<td>Special guests:</td>
		<td><textarea name="" rows="" cols=""></textarea></td>
	</tr>
	<tr>
		<td colspan=2><center><input type="submit"></center></td>
		
	</tr>
	</table>
</form></center>
